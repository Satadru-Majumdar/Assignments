class ExportProfile:
    def __init__(self, resolution, file_type):
        self.resolution = resolution
        self.file_type = file_type

    def show(self):
        return f"{self.resolution} as a {self.file_type}"

def get_settings():
    print("Let's get your export settings ready.")
    
    destination = input("Where are you planning to post or use this? (e.g., Instagram or Print): ").strip().lower()
    
    if destination == "instagram":
        return ExportProfile("1080x1350", "JPEG")
        
    elif destination == "print":
        return ExportProfile("High-Res 4K+", "TIFF")
        
    else:
        print("I'm not familiar with that one, so let's just stick to standard web settings for now.")
        return ExportProfile("1920x1080", "PNG")

if __name__ == "__main__":
    profile = get_settings()
    
    print("\nHere is what you should use:")
    print(profile.show())
    print("\n")
